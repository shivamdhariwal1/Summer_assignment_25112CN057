#include<stdio.h>
int main()
{
    int i,j,num;
    char ch;
    printf("Enter The Number Of Rows");
    scanf("%d",&num);
    for(i=1;i<=num;i++)
    {
        int a=65;
        for(j=1;j<=i;j++)
        {
            ch=(char)a;
            printf("%c ",ch);
            a++;
        }
        printf("\n");
    }
    return 0;
}