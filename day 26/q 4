#include <stdio.h>
#include <ctype.h>
struct Question 
{
    char question_text[150];
    char options[4][50];
    char correct_answer;
};
int main() {
    int score = 0;
    char user_answer;
    int total_questions = 3;
    struct Question quiz[3] = {
        {
            "Which programming language is known as the 'mother of all languages'?",
            {"A. Python", "B. C", "C. Java", "D. C++"},
            'B'
        },
        {
            "What is the size of an 'int' data type in C (typically on 32/64-bit systems)?",
            {"A. 1 Byte", "B. 2 Bytes", "C. 4 Bytes", "D. 8 Bytes"},
            'C'
        },
        {
            "Which keyword is used to prevent a variable from being modified in C?",
            {"A. static", "B. volatile", "C. register", "D. const"},
            'D'
        }
    };
    printf("======================================\n");
    printf("      WELCOME TO THE TECH QUIZ        \n");
    printf("======================================\n\n");
    printf("Instructions: Type A, B, C, or D for each question.\n\n");
    for (int i = 0; i < total_questions; i++) {
        printf("Question %d: %s\n", i + 1, quiz[i].question_text);
        for (int j = 0; j < 4; j++) {
            printf("%s\n", quiz[i].options[j]);
        }
        while (1) {
            printf("Your Answer: ");
            scanf(" %c", &user_answer); 
            user_answer = toupper(user_answer); 
            if (user_answer >= 'A' && user_answer <= 'D') {
                break; 
            }
            printf("❌ Invalid choice! Please enter A, B, C, or D.\n");
        }
        if (user_answer == quiz[i].correct_answer) {
            printf("🎉 Correct!\n\n");
            score++;
        } else {
            printf("❌ Wrong! The correct answer was %c.\n\n", quiz[i].correct_answer);
        }
    }
    printf("======================================\n");
    printf("             QUIZ OVER!               \n");
    printf("======================================\n");
    printf("Your Final Score: %d out of %d\n", score, total_questions);
    if (score == total_questions) {
        printf("Perfect score! You're a master. 🏆\n");
    } else if (score >= total_questions / 2) {
        printf("Good job! You passed. 👍\n");
    } else {
        printf("Better luck next time! 📚\n");
    }
    printf("======================================\n");
    return 0;
}