#include <stdio.h>
int main() 
{
    int num, i, j, isSymmetric = 1;
    printf("Enter the order of the matrix: ");
    scanf("%d", &num);
    int a[num][num];
    printf("Enter the elements of the matrix:\n");
    for (i = 0; i < num; i++) {
        for (j = 0; j < num; j++) {
            scanf("%d", &a[i][j]);
        }
    }
    for (i = 0; i < num; i++) {
        for (j = 0; j < num; j++) {
            if (a[i][j] != a[j][i]) {
                isSymmetric = 0;
                break;
            }
        }
        if (!isSymmetric)
            break;
    }
    if (isSymmetric)
        printf("The matrix is symmetric.\n");
    else
        printf("The matrix is not symmetric.\n");
        return 0;
}