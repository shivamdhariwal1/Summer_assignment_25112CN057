#include <stdio.h>
#include <math.h>
int isArmstrong(int num)
{
    int originalNum = num;
    int sum = 0;
    int digits = 0;
    int temp = num;
    while (temp > 0) 
    {
        temp=temp/10;
        digits++;
        
    }
    temp = num;
    while (temp > 0) 
    {
        int rem = temp % 10;
        sum=sum+pow(rem,digits);
        temp=temp/10;
    }

    return (sum == originalNum);
}

int main()
{
    int start, end;
    printf("Enter the starting number: ");
    scanf("%d", &start);
    printf("Enter the ending number: ");
    scanf("%d", &end);

    printf("Armstrong numbers between %d and %d are:\n", start, end);

    for (int i = start; i <= end; i++) 
    {
        if (isArmstrong(i)) 
        {
            printf("%d ", i);
        }
    }

    printf("\n");
    return 0;
}