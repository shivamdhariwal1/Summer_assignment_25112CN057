#include <stdio.h>
#include <string.h>
#include <stdlib.h>
void compressString(char *src) {
    int len = strlen(src);
    if (len == 0) return;
    char *dest = (char *)malloc(sizeof(char) * (2 * len + 1));
    if (dest == NULL) {
        printf("Memory allocation failed.\n");
        return;
    }
    int i, j = 0;
    for (i = 0; i < len; i++) {
        dest[j++] = src[i];
        int count = 1;
        while (i + 1 < len && src[i] == src[i + 1]) {
            count++;
            i++;
        }
        j += sprintf(&dest[j], "%d", count);
    }
    dest[j] = '\0';
    printf("Compressed String: %s\n", dest);
    free(dest);
}
int main() {
    char str[] = "AAAABBBCCDAA";
    printf("Original String:   %s\n", str);
    compressString(str);
    return 0;
}