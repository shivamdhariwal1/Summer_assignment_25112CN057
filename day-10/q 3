#include<stdio.h>
int main()
{
    int i, j, k, num;
    printf("Enter The Number Of Rows: ");
    scanf("%d", &num);
    for(i = 1; i <= num; i++)
    {
        for(k = 1; k <= i - 1; k++)
        {
            printf(" ");
        }
        for(j = 1; j <= (2*num - 2*i + 1); j++)
        {
            printf("*");
        }
        printf("\n");
    }
    return 0;
}