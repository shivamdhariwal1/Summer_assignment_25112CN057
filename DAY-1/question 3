#include<stdio.h>
int main(){
    int n;
    long long factorial = 1;

    //Ask the user to enter the number of his choice
    printf("enter a positive number");
    scanf("%d", &n);
     //use loop to calculate the fctorial 
      for (int i = 1; i <= n; i++) {
        factorial = factorial * i;
    }

    // Display the result
    printf("Factorial of %d = %lld\n", n, factorial);

    return 0; // Indicate successful execution
}
